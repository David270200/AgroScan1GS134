<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimary"
        app:title="@string/detail_title"
        app:titleTextColor="@color/colorWhite"
        app:navigationIcon="@drawable/ic_arrow_back" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/colorWhite"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/ivPlantThumb"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/rounded_green_bg"
                        android:src="@drawable/ic_leaf"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvPlantName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nombre planta"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorText" />

                        <TextView
                            android:id="@+id/tvCropInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tipo · Fecha"
                            android:textSize="11sp"
                            android:textColor="@color/colorTextSecondary"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:id="@+id/tvDiagnosisTag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Diagnóstico"
                            android:textSize="11sp"
                            android:textColor="#C62828"
                            android:background="@drawable/tag_red"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/colorRedLight"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvDiagnosisTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Diagnóstico"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#B71C1C"
                        android:layout_marginBottom="8dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Descripción" android:textSize="11sp" android:textColor="@color/colorTextSecondary" />
                    <TextView android:id="@+id/tvDescription" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="" android:textSize="13sp" android:textColor="@color/colorText" android:layout_marginBottom="8dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Causas" android:textSize="11sp" android:textColor="@color/colorTextSecondary" />
                    <TextView android:id="@+id/tvCauses" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="" android:textSize="13sp" android:textColor="@color/colorText" android:layout_marginBottom="8dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tratamiento" android:textSize="11sp" android:textColor="@color/colorTextSecondary" />
                    <TextView android:id="@+id/tvTreatment" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="" android:textSize="13sp" android:textColor="@color/colorText" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/diagnosis_history"
                    android:textSize="13sp"
                    android:textColor="@color/colorTextSecondary" />

                <Button
                    android:id="@+id/btnAddHistory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ Añadir"
                    android:textSize="11sp"
                    android:textColor="#000000" />
            </LinearLayout>

            <DatePicker
                android:id="@+id/datePicker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:calendarViewShown="true"
                android:spinnersShown="false"
                android:layout_marginBottom="8dp" />

            <ListView
                android:id="@+id/lvHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:divider="@null"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
